# North Link Backend — Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to version control

# ── Application ──────────────────────────────
APP_NAME="North Link API"
APP_ENV=development          # development | staging | production
APP_DEBUG=true               # true in dev, false in production

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://northlink:northlink@localhost:5432/northlink

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Authentication ───────────────────────
JWT_SECRET=change-me-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Encryption (AES-256 for sensitive fields) ─
ENCRYPTION_KEY=change-me-to-32-bytes-long-key!!

# ── Exchange Rate API ────────────────────────
EXCHANGE_RATE_API_KEY=

# ── Sentry (Error Tracking) ──────────────────
SENTRY_DSN=
